# Copy this file to .env and fill in your API keys
# None of these are required — the system gracefully degrades
# with fewer APIs (see LLM fallback chain in rag_pipeline/config.py)

# ── LLM providers (at least one required for RAG pipelines) ──────
GROQ_API_KEY=           # https://console.groq.com — fast, free tier
GEMINI_API_KEY=         # https://aistudio.google.com — generous free quota
NVIDIA_API_KEY=         # https://build.nvidia.com — 1M context, free credits
OPENROUTER_API_KEY=     # https://openrouter.ai — last-resort fallback

# ── Embeddings (required for FAISS index and P2–P5 pipelines) ────
# NVIDIA_API_KEY above doubles as the embeddings key

# ── Web search fallback ───────────────────────────────────────────
TAVILY_API_KEY=         # https://tavily.com — web search when DB results are weak

# ── Project path (optional override) ─────────────────────────────
# CF_PROJECT_DIR=/path/to/cf_final_project   # defaults to repo root auto-detect
# CF_CUDA_DEVICE=1                           # GPU device index (default: not set)
