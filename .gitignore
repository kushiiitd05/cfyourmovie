rag_pipeline/matrices/
# faiss_index/ = FAISS dense index (run build_index.py)
rag_pipeline/faiss_index/
# bm25_index/ = BM25 pickle (run build_bm25_index.py)
rag_pipeline/bm25_index/
rag_pipeline/train.log

# ── Jupyter ────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Environment / secrets ──────────────────────────────────────
.env
*.env
.env.*
!.env.example

